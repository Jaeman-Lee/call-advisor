WATCH_DIR='/storage/emulated/0/Recordings/Call'
OUTPUT_DIR='/storage/emulated/0/Recordings/CallAnalysis'

# Optional: copy results into an Obsidian vault and open notifications there.
OBSIDIAN_VAULT_DIR=
OBSIDIAN_VAULT_NAME=
OBSIDIAN_FOLDER='CallAnalysis'

WATCH_MODE=auto
POLL_SECONDS=300
STABLE_SECONDS=3
SCAN_EXISTING=false

LANGUAGE=ko
THREADS=6
EFFORT=low
CODEX_ENABLED=true
NOTIFY=true

# local: phone only, remote: PC only (unless fallback), auto: prefer PC.
TRANSCRIBE_BACKEND=local
LOCAL_FALLBACK=true

# Keep real host names, addresses and key paths only in call-advisor.conf.
REMOTE_SSH_HOST='user@pc-tailscale-name'
REMOTE_SSH_PORT=22
REMOTE_SSH_KEY="$HOME/.ssh/id_ed25519"
REMOTE_DIR='whisper-server'
REMOTE_MODEL='models/ggml-medium-q5_0.bin'
REMOTE_VAD_MODEL='models/ggml-silero-v6.2.0.bin'
REMOTE_THREADS=6
REMOTE_CONNECT_TIMEOUT=8

# The phone fallback remains base. Change only the remote model after benchmarking.
WHISPER_DIR="$APP_DIR/tools/whisper.cpp"
WHISPER_BIN="$WHISPER_DIR/build/bin/whisper-cli"
WHISPER_MODEL="$WHISPER_DIR/models/ggml-base.bin"
VAD_ENABLED=true
VAD_BIN="$WHISPER_DIR/build/bin/whisper-vad-speech-segments"
VAD_MODEL="$WHISPER_DIR/models/ggml-silero-v6.2.0.bin"
VAD_THRESHOLD=0.50
VAD_TRANSCRIBE_MAX_DENSITY=80

PROMPT='다음은 전화 통화의 자동 전사문입니다. 한국어로 핵심 요약, 합의된 내용, 해야 할 일과 담당자, 일정이나 날짜, 다시 확인할 사항을 구분하세요. 전사 오류 가능성이 있는 고유명사와 숫자는 불확실하다고 표시하세요. 추측으로 내용을 만들지 마세요.'
